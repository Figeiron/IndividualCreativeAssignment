@startuml
skinparam style strictuml
skinparam packageStyle rectangle
skinparam linetype ortho

package "Core" {
    abstract class Command {
        + name: str
        + description: str
        + execute(context)
        + {static} get_params(service)
        {abstract} # _execute(context)
    }

    abstract class Service {
        + {static} displayed_name: str
        + context: AppContext
        + commands: dict
        + register_command(name, command_cls)
        + get_command_params(command_name): list
        + emit_event(event)
    }

    class Event {
        + type: EventType
        + data: dict
        + __init__(type, **data)
    }

    enum EventType {
        START
        IDLE
        STEP
        FINISH
        UPDATE
        ERROR
        EXIT
        SERVICE_AVAILABLE
        SERVICE_SELECTED
        COMMAND_AVAILABLE
        SHOW_SERVICES_MENU
        COMMAND_SELECTED
        COMMAND_EXECUTED
        EXECUTE_COMMAND
        EASTER_EGG
        RUN_COMMAND
    }

    class EventDispatcher {
        - _queue: deque
        - _subscribers: list
        + has_events(): bool
        + emit(event)
        + next_event(): Event
        + subscribe(listener)
        + dispatch()
    }

    class Parameter << (D,orchid) >> {
        + name: str
        + display_name: str
        + description: str
        + parse: Callable
        + validators: List[Validator]
        + convert(value: str): Any
    }

    abstract class Validator {
        + {abstract} __call__(value)
    }

    class RangeValidator {
        + min_val: Any
        + max_val: Any
        + __call__(value)
    }

    exception ValidationError {
    }
}

package "App" {
    class Application {
        + context: AppContext
        + services: dict
        + running: bool
        + handle_event(event)
        + register_service(name, service)
        + run_command(command)
        + run()
        + run_with_gui(viewer)
    }

    class AppContext {
        + data: dict
        + events: EventDispatcher
    }
}

package "UI" {
    class ConsoleViewer {
        + context: AppContext
        + commands: dict
        + services: dict
        + exit_menu: dict
        + running: bool
        + handle_event(event)
        {static} + print_banner(title)
        + show_service_menu()
        + show_exit_menu()
        + pick_exit_menu_command()
        + pick_service()
        + show_commands(service_name)
        + pick_command(service_name)
        + execute_command(command_cls, service, command_name)
    }

    class TkinterViewer {
        + context: AppContext
        + root: tk.Tk
        + sidebar: tk.Frame
        + main_area: tk.Frame
        + services: dict
        + commands: dict
        + handle_event(event)
        + show_services_sidebar()
        + show_commands_sidebar(service_name)
        + show_params_form(service_name, command_name)
        + collect_and_execute(command_cls, service, params_meta)
        + execute_with_params(command_cls, service, args)
        + update_gui()
        + on_closing()
    }
}

package "Utils" {
    class TriggerListener {
        + context: AppContext
        + correct_order: list
        - sequence: deque
        + handle_event(event)
        + trigger()
    }
}

package "Modules: About" {
    class AboutService {
        + displayed_name: str = "Про розробника"
        + get_about_creator(): str
        + get_about_program(): str
    }

    class GetAboutCreator {
        + service: AboutService
        + name: str
        + description: str
        # _execute(context)
    }

    class GetAboutProgram {
        + service: AboutService
        + name: str
        + description: str
        # _execute(context)
    }
}

package "Modules: MetalCalc" {
    class MetalCalcService {
        + displayed_name: str = "Калькулятор тонколистового металу"
        + materials: list
        + get_materials(): str
        + calculate_pipe_unfolding(diameter, length, material_index): str
        + calculate_elbow_unfolding(diameter, angle, segments, material_index): str
        + get_command_params(command_name): list
    }

    class GetMaterialsCommand {
        + service: MetalCalcService
        # _execute(context)
    }

    class CalculatePipeCommand {
        + service: MetalCalcService
        + diameter: float
        + length: float
        + material_index: int
        # _execute(context)
    }

    class CalculateElbowCommand {
        + service: MetalCalcService
        + diameter: float
        + angle: float
        + segments: int
        + material_index: int
        # _execute(context)
    }
}

Service <|-- AboutService
Service <|-- MetalCalcService
Command <|-- GetAboutCreator
Command <|-- GetAboutProgram
Command <|-- GetMaterialsCommand
Command <|-- CalculatePipeCommand
Command <|-- CalculateElbowCommand

Validator <|-- RangeValidator
Parameter "1" o-- "*" Validator
Command ..> Parameter : uses
Service ..> Parameter : uses

Application "1" *-- "1" AppContext
AppContext "1" *-- "1" EventDispatcher

AboutService "1" o-- "2" Command : registers
MetalCalcService "1" o-- "3" Command : registers
EventDispatcher "1" o-- "*" Event : manages
Event "*" -- "1" EventType

EventDispatcher o-- "*" ConsoleViewer : notifies
EventDispatcher o-- "*" TkinterViewer : notifies
EventDispatcher o-- "*" TriggerListener : notifies
EventDispatcher o-- "1" Application : notifies

Application "1" o-- "*" Service : manages

@enduml
